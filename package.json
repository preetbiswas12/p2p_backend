{
  "name": "octatecode-p2p-backend",
  "version": "1.0.0",
  "description": "Standalone P2P collaboration server for OctateCode - Production Ready Backend",
  "type": "module",
  "main": "./build/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node build/index.js",
    "watch": "tsc --watch",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "p2p",
    "collaboration",
    "webrtc",
    "signaling",
    "crdt",
    "operational-transform"
  ],
  "author": "OctateCode",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.14.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "@supabase/supabase-js": "^2.38.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.20",
    "@types/node": "^20.8.0",
    "@types/ws": "^8.5.8",
    "@types/jsonwebtoken": "^9.0.5",
    "typescript": "^5.2.2",
    "tsx": "^4.6.2",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
